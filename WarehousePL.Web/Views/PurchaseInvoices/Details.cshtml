@using WarehouseDAL.Entities.Enums
@model WarehouseDAL.Entities.PurchaseInvoice
@{
    ViewBag.Title = "تفاصيل فاتورة مشتريات";
}

<div class="card" id="invoice-print-area">
    {{!-- هيدر الطباعة (يظهر فقط عند الطباعة) --}}
    <div class="d-none d-print-block text-center mb-3 pt-3">
        <h4 class="fw-bold">فاتورة مشتريات</h4>
        <p class="text-muted">@Model.InvoiceNumber — @Model.InvoiceDate.ToString("yyyy/MM/dd")</p>
    </div>

    <div class="card-header d-flex justify-content-between align-items-center d-print-none">
        <h5 class="mb-0">
            <i class="ti ti-file-invoice me-1 text-primary"></i>
            فاتورة رقم: <span class="text-primary">@Model.InvoiceNumber</span>
        </h5>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-label-secondary" onclick="window.print()">
                <i class="ti ti-printer me-1"></i> طباعة
            </button>
            <a asp-action="Index" class="btn btn-sm btn-label-secondary">
                <i class="ti ti-arrow-right me-1"></i> رجوع
            </a>
        </div>
    </div>

    <div class="card-body">
        {{!-- بيانات الفاتورة الرئيسية --}}
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100 bg-light">
                    <small class="text-muted d-block">رقم الفاتورة</small>
                    <span class="fw-bold text-primary fs-6">@Model.InvoiceNumber</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100 bg-light">
                    <small class="text-muted d-block">التاريخ</small>
                    <span class="fw-bold">@Model.InvoiceDate.ToString("yyyy/MM/dd")</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100 bg-light">
                    <small class="text-muted d-block">المورد</small>
                    <span class="fw-bold">@Model.Supplier?.Name</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100 bg-light">
                    <small class="text-muted d-block">الحالة</small>
                    @{
                        var (statusClass, statusText) = Model.Status switch
                        {
                            InvoiceStatus.Paid           => ("bg-label-success", "مدفوعة بالكامل"),
                            InvoiceStatus.PartiallyPaid  => ("bg-label-warning", "مدفوعة جزئياً"),
                            InvoiceStatus.Cancelled      => ("bg-label-danger",  "ملغاة"),
                            _                            => ("bg-label-secondary","مسودة")
                        };
                    }
                    <span class="badge @statusClass px-2 py-1">@statusText</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100 bg-light">
                    <small class="text-muted d-block">الفرع</small>
                    <span class="fw-bold">@Model.Branch?.Name</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100 bg-light">
                    <small class="text-muted d-block">المخزن</small>
                    <span class="fw-bold">@Model.Warehouse?.Name</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100 bg-light">
                    <small class="text-muted d-block">طريقة الدفع</small>
                    @if (Model.PaymentMethod == PaymentMethod.Cash)
                    {
                        <span class="badge bg-label-success px-2 py-1">
                            كاش — @(Model.CashBox?.Name ?? "")
                        </span>
                    }
                    else if (Model.PaymentMethod == PaymentMethod.Credit)
                    {
                        <span class="badge bg-label-warning px-2 py-1">آجل</span>
                    }
                    else
                    {
                        <span class="badge bg-label-info px-2 py-1">تحويل بنكي</span>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="col-md-3">
                    <div class="border rounded p-3 h-100 bg-light">
                        <small class="text-muted d-block">ملاحظات</small>
                        <span>@Model.Notes</span>
                    </div>
                </div>
            }
        </div>

        {{!-- جدول عناصر الفاتورة --}}
        <h6 class="fw-bold mb-3 text-primary">
            <i class="ti ti-list-details me-1"></i> عناصر الفاتورة
        </h6>
        <div class="table-responsive mb-4">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>المنتج</th>
                        <th>الوحدة</th>
                        <th class="text-center">الكمية</th>
                        <th class="text-end">سعر الوحدة</th>
                        <th class="text-end">خصم السطر</th>
                        <th class="text-end">الإجمالي</th>
                    </tr>
                </thead>
                <tbody>
                    @{int rowNum = 1;}
                    @foreach (var item in Model.PurchaseInvoiceItems)
                    {
                        <tr>
                            <td class="text-muted">@rowNum</td>
                            <td>
                                <div class="fw-bold">@item.Product?.Name</div>
                                <small class="text-muted">@item.Product?.Code</small>
                            </td>
                            <td>@item.Unit?.Name</td>
                            <td class="text-center fw-bold">@item.Quantity.ToString("N3")</td>
                            <td class="text-end">@item.UnitPrice.ToString("N2")</td>
                            <td class="text-end text-danger">
                                @(item.Discount > 0 ? item.Discount.ToString("N2") : "—")
                            </td>
                            <td class="text-end fw-bold text-primary">@item.Total.ToString("N2")</td>
                        </tr>
                        rowNum++;
                    }
                </tbody>
            </table>
        </div>

        {{!-- ملخص الحسابات --}}
        <div class="row justify-content-end">
            <div class="col-md-5 col-lg-4">
                <table class="table table-sm table-bordered mb-0">
                    <tr>
                        <td class="text-end fw-bold">إجمالي الأصناف:</td>
                        <td class="text-end fw-bold">@Model.Total.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="text-end">خصم الفاتورة:</td>
                        <td class="text-end text-danger">@Model.Discount.ToString("N2")</td>
                    </tr>
                    <tr class="table-primary">
                        <td class="text-end fw-bold">الصافي:</td>
                        <td class="text-end fw-bold">@Model.Net.ToString("N2")</td>
                    </tr>
                    <tr class="table-success">
                        <td class="text-end fw-bold">المدفوع:</td>
                        <td class="text-end fw-bold text-success">@Model.Paid.ToString("N2")</td>
                    </tr>
                    <tr class="@(Model.Remaining > 0 ? "table-danger" : "")">
                        <td class="text-end fw-bold">المتبقي (آجل):</td>
                        <td class="text-end fw-bold @(Model.Remaining > 0 ? "text-danger" : "text-muted")">
                            @Model.Remaining.ToString("N2")
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    {{!-- Footer زرار الطباعة --}}
    <div class="card-footer d-flex justify-content-between align-items-center d-print-none">
        <a asp-action="Index" class="btn btn-label-secondary">
            <i class="ti ti-arrow-right me-1"></i> رجوع للقائمة
        </a>
        <button type="button" class="btn btn-primary" onclick="window.print()">
            <i class="ti ti-printer me-1"></i> طباعة الفاتورة
        </button>
    </div>
</div>

@section Styles {
    <style>
        @@media print {
            .layout-wrapper, .layout-menu, .layout-navbar, .content-backdrop,
            .drag-target, .layout-overlay { display: none !important; }

            .layout-page { margin: 0 !important; padding: 0 !important; }
            .content-wrapper { margin: 0 !important; padding: 0 !important; }
            .container-xxl { padding: 0 !important; max-width: 100% !important; }

            #invoice-print-area {
                border: none !important;
                box-shadow: none !important;
                padding: 10px;
            }

            body { font-size: 13px !important; }
            .table { font-size: 12px !important; }
        }
    </style>
}
