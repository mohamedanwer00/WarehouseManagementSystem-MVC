@model WarehouseBLL.FormViewModels.PurchaseInvoice.PurchaseInvoiceFormViewModel
@{
    ViewBag.Title = "إضافة فاتورة مشتريات";
}

@* Alert أخطاء الـ ModelState *@
@if (!ViewData.ModelState.IsValid)
{
    var errors = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => e.ErrorMessage)
        .Where(m => !string.IsNullOrEmpty(m))
        .ToList();
    if (errors.Any())
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <strong><i class="ti ti-alert-circle me-1"></i> يوجد أخطاء:</strong>
            <ul class="mb-0 mt-1">@foreach (var e in errors){<li>@e</li>}</ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
}

<form asp-action="Create" method="post" id="invoice-form">
    @Html.AntiForgeryToken()

    {{!-- بيانات الهيدر --}}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="ti ti-file-invoice me-1 text-primary"></i>
                إضافة فاتورة مشتريات
            </h5>
            <a asp-action="Index" class="btn btn-sm btn-label-secondary">
                <i class="ti ti-arrow-right me-1"></i> رجوع
            </a>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold">رقم الفاتورة</label>
                    <input asp-for="InvoiceNumber" class="form-control" />
                    <span asp-validation-for="InvoiceNumber" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">التاريخ <span class="text-danger">*</span></label>
                    <input asp-for="InvoiceDate" class="form-control" type="date"
                           value="@Model.InvoiceDate.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="InvoiceDate" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">الفرع <span class="text-danger">*</span></label>
                    <select asp-for="BranchId" asp-items="Model.Branches" class="form-select">
                        <option value="">-- اختر الفرع --</option>
                    </select>
                    <span asp-validation-for="BranchId" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">المخزن <span class="text-danger">*</span></label>
                    <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select">
                        <option value="">-- اختر المخزن --</option>
                    </select>
                    <span asp-validation-for="WarehouseId" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">المورد <span class="text-danger">*</span></label>
                    <select asp-for="SupplierId" asp-items="Model.Suppliers" class="form-select">
                        <option value="">-- اختر المورد --</option>
                    </select>
                    <span asp-validation-for="SupplierId" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">طريقة الدفع <span class="text-danger">*</span></label>
                    <select asp-for="PaymentMethod" class="form-select" id="PaymentMethod">
                        <option value="1">كاش</option>
                        <option value="2">آجل</option>
                        <option value="3">تحويل بنكي</option>
                    </select>
                </div>
                <div class="col-md-4" id="cashbox-container">
                    <label class="form-label fw-bold">
                        الخزنة الصارفة <span class="text-danger" id="cashbox-star">*</span>
                    </label>
                    <select asp-for="CashBoxId" asp-items="Model.CashBoxes" class="form-select">
                        <option value="">-- اختر الخزنة --</option>
                    </select>
                    <span asp-validation-for="CashBoxId" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label class="form-label fw-bold">ملاحظات</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"
                              placeholder="ملاحظات اختيارية..."></textarea>
                </div>
            </div>
        </div>
    </div>

    {{!-- جدول العناصر --}}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">
                <i class="ti ti-list-details me-1 text-primary"></i>
                عناصر الفاتورة
            </h6>
            <button type="button" class="btn btn-primary btn-sm" id="btn-add-item">
                <i class="ti ti-plus me-1"></i> إضافة عنصر
            </button>
        </div>
        <div class="card-body">
            <div id="alert-no-items" class="alert alert-warning d-none mb-3" role="alert">
                <i class="ti ti-alert-triangle me-1"></i> يجب إضافة عنصر واحد على الأقل.
            </div>
            <div class="table-responsive">
                <table class="table table-bordered align-middle" id="items-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width:30%">المنتج</th>
                            <th style="width:15%">الوحدة</th>
                            <th style="width:12%">الكمية</th>
                            <th style="width:13%">سعر الوحدة</th>
                            <th style="width:12%">خصم السطر</th>
                            <th style="width:13%">الإجمالي</th>
                            <th style="width:5%"></th>
                        </tr>
                    </thead>
                    <tbody id="items-body">
                        {{!-- الأسطر تُضاف بـ JS --}}
                    </tbody>
                </table>
            </div>

            {{!-- ملخص الحسابات --}}
            <div class="row justify-content-end mt-3">
                <div class="col-md-5 col-lg-4">
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="fw-bold text-end">الإجمالي:</td>
                            <td style="width:120px">
                                <input asp-for="Total" id="Total"
                                       class="form-control form-control-sm text-end" readonly value="0.00" />
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-end">خصم الفاتورة:</td>
                            <td>
                                <input asp-for="Discount" id="Discount"
                                       class="form-control form-control-sm text-end calc-trigger"
                                       type="number" step="0.01" min="0" value="0.00" />
                            </td>
                        </tr>
                        <tr class="table-primary">
                            <td class="fw-bold text-end">الصافي:</td>
                            <td>
                                <input asp-for="Net" id="Net"
                                       class="form-control form-control-sm text-end fw-bold" readonly value="0.00" />
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-end">المدفوع:</td>
                            <td>
                                <input asp-for="Paid" id="Paid"
                                       class="form-control form-control-sm text-end calc-trigger"
                                       type="number" step="0.01" min="0" value="0.00" />
                            </td>
                        </tr>
                        <tr class="table-danger">
                            <td class="fw-bold text-end">المتبقي (آجل):</td>
                            <td>
                                <input asp-for="Remaining" id="Remaining"
                                       class="form-control form-control-sm text-end fw-bold" readonly value="0.00" />
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="card-footer text-end gap-2">
            <button type="submit" class="btn btn-success me-2" id="btn-save">
                <i class="ti ti-device-floppy me-1"></i> حفظ الفاتورة
            </button>
            <a asp-action="Index" class="btn btn-label-secondary">إلغاء</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            let itemIndex = 0;
            let allProducts = [];

            // ===== جلب المنتجات مرة واحدة =====
            $.getJSON('@Url.Action("GetAllProducts", "PurchaseInvoices")', function (data) {
                allProducts = data;
            });

            // ===== إظهار/إخفاء الخزنة حسب طريقة الدفع =====
            function toggleCashBox() {
                const method = parseInt($('#PaymentMethod').val());
                if (method === 2) { // آجل
                    $('#cashbox-container').hide();
                    $('#Paid').val('0.00').prop('readonly', true);
                    $('#CashBoxId').val('');
                } else {
                    $('#cashbox-container').show();
                    $('#Paid').prop('readonly', false);
                }
                calculateTotals();
            }
            $('#PaymentMethod').on('change', toggleCashBox);
            toggleCashBox(); // تشغيل عند الـ load

            // ===== بناء HTML سطر المنتج =====
            function buildRow(index) {
                let productOptions = '<option value="">-- اختر المنتج --</option>';
                allProducts.forEach(function (p) {
                    productOptions += `<option value="${p.id}">[${p.code}] ${p.name}</option>`;
                });

                return `
                <tr class="item-row">
                    <td>
                        <select name="Items[${index}].ProductId"
                                class="form-select form-select-sm select-product" required>
                            ${productOptions}
                        </select>
                    </td>
                    <td>
                        <select name="Items[${index}].UnitId"
                                class="form-select form-select-sm select-unit" required>
                            <option value="">-- اختر الوحدة --</option>
                        </select>
                    </td>
                    <td>
                        <input name="Items[${index}].Quantity"
                               class="form-control form-control-sm text-center row-qty"
                               type="number" step="0.001" min="0.001" value="1" required />
                    </td>
                    <td>
                        <input name="Items[${index}].UnitPrice"
                               class="form-control form-control-sm text-end row-price"
                               type="number" step="0.01" min="0" value="0.00" required />
                    </td>
                    <td>
                        <input name="Items[${index}].Discount"
                               class="form-control form-control-sm text-end row-disc"
                               type="number" step="0.01" min="0" value="0.00" />
                    </td>
                    <td>
                        <input name="Items[${index}].Total"
                               class="form-control form-control-sm text-end row-total bg-light"
                               type="number" readonly value="0.00" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-label-danger btn-remove-row"
                                title="حذف السطر">
                            <i class="ti ti-trash"></i>
                        </button>
                    </td>
                </tr>`;
            }

            // ===== إضافة سطر =====
            $('#btn-add-item').on('click', function () {
                $('#items-body').append(buildRow(itemIndex));
                itemIndex++;
                $('#alert-no-items').addClass('d-none');
            });

            // ===== عند اختيار المنتج — جلب وحداته =====
            $(document).on('change', '.select-product', function () {
                const $row     = $(this).closest('tr');
                const $unitSel = $row.find('.select-unit');
                const productId = $(this).val();

                $unitSel.html('<option value="">جاري التحميل...</option>');

                if (!productId) {
                    $unitSel.html('<option value="">-- اختر الوحدة --</option>');
                    $row.find('.row-price').val('0.00');
                    calcRow($row);
                    return;
                }

                $.getJSON('@Url.Action("GetProductUnits", "PurchaseInvoices")', { productId: productId },
                    function (units) {
                        let opts = '<option value="">-- اختر الوحدة --</option>';
                        units.forEach(function (u) {
                            opts += `<option value="${u.id}" data-price="${u.purchasePrice}">${u.name}</option>`;
                        });
                        $unitSel.html(opts);

                        // اختيار الوحدة الأساسية تلقائياً وسعرها
                        const base = units.find(u => u.isBaseUnit);
                        if (base) {
                            $unitSel.val(base.id);
                            $row.find('.row-price').val(parseFloat(base.purchasePrice).toFixed(2));
                            calcRow($row);
                        }
                    }
                );
            });

            // ===== عند اختيار الوحدة — تحديث السعر =====
            $(document).on('change', '.select-unit', function () {
                const $row  = $(this).closest('tr');
                const price = $(this).find('option:selected').data('price') || 0;
                $row.find('.row-price').val(parseFloat(price).toFixed(2));
                calcRow($row);
            });

            // ===== حساب إجمالي السطر =====
            function calcRow($row) {
                const qty   = parseFloat($row.find('.row-qty').val())   || 0;
                const price = parseFloat($row.find('.row-price').val()) || 0;
                const disc  = parseFloat($row.find('.row-disc').val())  || 0;
                const total = Math.max(0, qty * price - disc);
                $row.find('.row-total').val(total.toFixed(2));
                calculateTotals();
            }

            $(document).on('input', '.row-qty, .row-price, .row-disc', function () {
                calcRow($(this).closest('tr'));
            });

            // ===== حساب الإجماليات الكلية =====
            function calculateTotals() {
                let grandTotal = 0;
                $('.row-total').each(function () {
                    grandTotal += parseFloat($(this).val()) || 0;
                });

                $('#Total').val(grandTotal.toFixed(2));

                const disc = parseFloat($('#Discount').val()) || 0;
                const net  = Math.max(0, grandTotal - disc);
                $('#Net').val(net.toFixed(2));

                const method = parseInt($('#PaymentMethod').val());
                if (method === 2) $('#Paid').val('0.00');

                const paid      = parseFloat($('#Paid').val()) || 0;
                const remaining = Math.max(0, net - paid);
                $('#Remaining').val(remaining.toFixed(2));
            }

            $(document).on('input', '.calc-trigger', calculateTotals);

            // ===== حذف سطر =====
            $(document).on('click', '.btn-remove-row', function () {
                $(this).closest('tr').remove();
                reIndex();
                calculateTotals();
            });

            // ===== إعادة ترتيب الـ Indexes =====
            function reIndex() {
                itemIndex = 0;
                $('#items-body tr').each(function () {
                    $(this).find('select, input').each(function () {
                        const name = $(this).attr('name');
                        if (name && name.startsWith('Items[')) {
                            $(this).attr('name', name.replace(/\[\d+\]/, '[' + itemIndex + ']'));
                        }
                    });
                    itemIndex++;
                });
            }

            // ===== التحقق قبل الحفظ =====
            $('#invoice-form').on('submit', function (e) {
                if ($('#items-body tr').length === 0) {
                    e.preventDefault();
                    $('#alert-no-items').removeClass('d-none');
                    $('html, body').animate({ scrollTop: $('#alert-no-items').offset().top - 100 }, 400);
                    return false;
                }
            });
        });
    </script>
}
