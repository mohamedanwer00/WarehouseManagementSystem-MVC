@using WarehouseBLL.BusinessServices.View_Models.PurchaseInvoice
@using WarehouseBLL.Const

@model IEnumerable<PurchaseInvoiceViewModel>

@{
    ViewBag.Title = _localization["PurchaseInvoices"];
}

<div class="card">
    <div class="card-datatable text-nowrap">
        <table class="js-table datatables-basic table table-bordered table-responsive">
            <thead>
                <tr>
                    <th>@_localization["InvoiceNumber"]</th>
                    <th>@_localization["InvoiceDate"]</th>
                    <th>@_localization["Supplier"]</th>
                    <th>@_localization["Branch"]</th>
                    <th>@_localization["Warehouse"]</th>
                    <th>@_localization["TotalAmount"]</th>
                    <th>@_localization["Paid"]</th>
                    <th>@_localization["Remaining"]</th>
                    <th>@_localization["PaymentMethod"]</th>
                    <th>@_localization["Status"]</th>
                    <th class="js-no-export">@_localization["Details"]</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var invoice in Model)
                {
                    <partial name="_Row" model="invoice" />
                }

            </tbody>

        </table>
    </div>
</div>

<div id="create-button-data"
     data-address="@_localization["PurchaseInvoices"]"
     data-title="@_localization[DisplayNames.Add]"
     data-url="@Url.Action("Create", "PurchaseInvoices")"
     data-label="@_localization[DisplayNames.Add]"
     data-mode="page">
</div>