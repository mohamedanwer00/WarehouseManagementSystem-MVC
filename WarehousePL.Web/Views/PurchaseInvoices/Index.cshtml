@using WarehouseBLL.BusinessServices.View_Models.PurchaseInvoice
@using WarehouseBLL.Const
@model IEnumerable<PurchaseInvoiceViewModel>

@{
    ViewBag.Title = "فواتير المشتريات";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center border-bottom mb-3">
        <h5 class="mb-0">إدارة فواتير المشتريات</h5>
        <!-- زرار الإضافة بيفتح صفحة كاملة مش مودال لأن الشاشة مركبة -->
        <a asp-action="Create" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> إضافة فاتورة جديدة
        </a>
    </div>

    <div class="card-datatable text-nowrap">
        <table class="js-table datatables-basic table table-bordered table-responsive">
            <thead>
                <tr>
                    <th>رقم الفاتورة</th>
                    <th>التاريخ</th>
                    <th>المورد</th>
                    <th>المخزن</th>
                    <th>طريقة الدفع</th>
                    <th>الصافي</th>
                    <th>المدفوع</th>
                    <th>المتبقي</th>
                    <th class="js-no-export">العمليات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in Model)
                {
                    <partial name="_Row" model="@invoice" />
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}