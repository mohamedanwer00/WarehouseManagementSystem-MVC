@using WarehouseBLL.FormViewModels.Product
@using System.Globalization
@model ProductFormViewModel

@* عرض أخطاء الـ ModelState كـ alert *@
@if (!ViewData.ModelState.IsValid)
{
    var errors = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => e.ErrorMessage)
        .Where(m => !string.IsNullOrEmpty(m))
        .ToList();

    if (errors.Any())
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <strong><i class="ti ti-alert-circle me-1"></i> يوجد أخطاء، يرجى مراجعة:</strong>
            <ul class="mb-0 mt-1">
                @foreach (var err in errors)
                {
                    <li>@err</li>
                }
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
}

<form asp-action="@(Model.Id == null ? "Create" : "Edit")" asp-controller="Products" method="post" class="row g-3">

    @if (Model.Id != null)
    {
        <input type="hidden" asp-for="Id" />
    }

    <div class="col-md-6">
        <label asp-for="Name" class="form-label">اسم المنتج</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Code" class="form-label">كود الصنف / الباركود</label>
        <input asp-for="Code" class="form-control" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="CategoryId" class="form-label">القسم / الفئة</label>
        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
            <option value="">اختر القسم</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="MinimumQuantity" class="form-label">الحد الادنى للمخزون</label>
        <input asp-for="MinimumQuantity" type="number" class="form-control" />
        <span asp-validation-for="MinimumQuantity" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="MaximumQuantity" class="form-label">الحد الأقصى للمخزون</label>
        <input asp-for="MaximumQuantity" type="number" class="form-control" />
        <span asp-validation-for="MaximumQuantity" class="text-danger"></span>
    </div>

    <hr />

    <div class="col-12 d-flex justify-content-between align-items-center">
        <h5>وحدات القياس والأسعار للصنف</h5>

        <button type="button" id="btn-add-unit" class="btn btn-primary btn-sm">
            إضافة وحدة جديدة
        </button>
    </div>

    <div class="col-12">
        <table class="table table-bordered" id="tbl-product-units">
            <thead>
                <tr>
                    <th>الوحدة</th>
                    <th>معامل التحويل</th>
                    <th>وحدة أساسية؟</th>
                    <th>سعر الشراء</th>
                    <th>سعر البيع</th>
                    <th>إجراء</th>
                </tr>
            </thead>

            <tbody>

                @for (int i = 0; i < Model.ProductUnits.Count; i++)
                {
                    <tr>
                        <td>
                            <input type="hidden" asp-for="ProductUnits[i].Id" />
                            <select asp-for="ProductUnits[i].UnitId"
                                    asp-items="Model.AllAvailableUnits"
                                    class="form-select form-select-sm select-unit-id">
                                <option value="">اختر</option>
                            </select>
                        </td>

                        <td>
                            <input asp-for="ProductUnits[i].Factor"
                                   class="form-control form-control-sm" />
                        </td>

                        <td class="text-center">

                            <input type="radio"
                                   class="base-unit-radio"
                                   name="IsBaseUnitRadio"
                                   @(Model.ProductUnits[i].IsBaseUnit ? "checked" : "") />

                            <input type="hidden"
                                   class="base-unit-hidden"
                                   name="ProductUnits[@i].IsBaseUnit"
                                   value="@(Model.ProductUnits[i].IsBaseUnit ? "true" : "false")" />

                        </td>

                        <td>
                            <input asp-for="ProductUnits[i].PurchasePrice"
                                   type="number"
                                   step="0.01"
                                   class="form-control form-control-sm" />
                        </td>

                        <td>
                            <input asp-for="ProductUnits[i].SellingPrice"
                                   type="number"
                                   step="0.01"
                                   class="form-control form-control-sm" />
                        </td>

                        <td>

                            <button type="button"
                                    class="btn btn-danger btn-remove-row">
                                حذف
                            </button>

                        </td>

                    </tr>
                }

            </tbody>
        </table>
    </div>

    <div class="col-12 text-center">

        <button type="submit" class="btn btn-primary">
            حفظ الصنف
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            إلغاء
        </a>

    </div>

</form>

<div id="unit-row-template" style="display:none;">
    <table>
        <tbody>
            <tr>

                <input type="hidden"
                       name="ProductUnits[{index}].Id"
                       value="0" />

                <td>
                    <select name="ProductUnits[{index}].UnitId"
                            class="form-select select-unit-id">

                        <option value="">اختر الوحدة</option>

                        @foreach (var item in Model.AllAvailableUnits!)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }

                    </select>
                </td>

                <td>
                    <input type="number"
                           name="ProductUnits[{index}].Factor"
                           class="form-control"
                           value="1" />
                </td>

                <td class="text-center">

                    <input type="radio"
                           class="base-unit-radio"
                           name="IsBaseUnitRadio" />

                    <input type="hidden"
                           class="base-unit-hidden"
                           name="ProductUnits[{index}].IsBaseUnit"
                           value="false" />

                </td>

                <td>
                    <input type="number"
                           step="0.01"
                           name="ProductUnits[{index}].PurchasePrice"
                           class="form-control"
                           value="0" />
                </td>

                <td>
                    <input type="number"
                           step="0.01"
                           name="ProductUnits[{index}].SellingPrice"
                           class="form-control"
                           value="0" />
                </td>

                <td>

                    <button type="button"
                            class="btn btn-danger btn-remove-row">
                        حذف
                    </button>

                </td>

            </tr>
        </tbody>
    </table>
</div>