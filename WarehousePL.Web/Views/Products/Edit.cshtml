@model WarehouseBLL.FormViewModels.Product.ProductFormViewModel
@{
    ViewBag.Title = "تعديل بيانات المنتج";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">تعديل الصنف: @Model.Name</h5>
        <a asp-action="Index" class="btn btn-label-secondary"><i class="ti ti-arrow-right me-1"></i> العودة للجدول</a>
    </div>
    <div class="card-body">
        <partial name="_Form" model="Model" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
                $(document).ready(function () {
            // دالة للتحقق من منع تكرار الوحدات وتحديث الـ Dropdowns
            function checkDuplicateUnits() {
                var selectedUnits = [];

                // تجميع كل الوحدات المختارة حالياً
                $('.select-unit-id').each(function () {
                    var val = $(this).val();
                    if (val) {
                        selectedUnits.push(val);
                    }
                });

                // إظهار/إخفاء الخيارات بناءً على الاختيارات السابقة
                $('.select-unit-id').each(function () {
                    var currentSelect = $(this);
                    var currentVal = currentSelect.val();

                    currentSelect.find('option').each(function () {
                        var optionVal = $(this).val();
                        if (optionVal && optionVal !== currentVal) {
                            if (selectedUnits.includes(optionVal)) {
                                $(this).hide(); // إخفاء الوحدة لو مختارة في سطر تاني
                            } else {
                                $(this).show(); // إظهارها لو مش مختارة
                            }
                        }
                    });
                });
            }

            // إضافة سطر جديد عند الضغط على الزر
            $('#btn-add-unit').click(function () {
                var index = $('#tbl-product-units tbody tr').length;
                var template = $('#unit-row-template table tbody').html().replaceAll('{index}', index);
                $('#tbl-product-units tbody').append(template);

                // تشغيل التحقق فور إضافة سطر جديد لإخفاء الوحدات المختارة مسبقاً
                checkDuplicateUnits();
            });

            // عند تغيير اختيار الوحدة في أي سطر
            $(document).on('change', '.select-unit-id', function () {
                var currentSelect = $(this);
                var currentVal = currentSelect.val();
                var duplicates = 0;

                // التأكد إذا كانت مختارة في سطر آخر
                $('.select-unit-id').each(function () {
                    if ($(this).val() === currentVal && currentVal !== "") {
                        duplicates++;
                    }
                });

                if (duplicates > 1) {
                    Swal.fire({
                        title: 'تنبيه!',
                        text: 'عذراً، لا يمكنك اختيار نفس الوحدة مرتين للمنتج الواحد.',
                        icon: 'warning',
                        confirmButtonText: 'تمام'
                    });
                    currentSelect.val(''); // تصفير الاختيار المكرر
                }

                // تحديث القوائم بعد التغيير
                checkDuplicateUnits();
            });

            // حذف سطر وإعادة ترتيب الـ Indexes وتحديث القوائم
            $(document).on('click', '.btn-remove-row', function () {
                $(this).closest('tr').remove();
                reIndexTable();
                checkDuplicateUnits(); // إعادة إظهار الوحدات التي تم حذف سطرها
            });

            // إدارة الـ Radio Button للوحدة الأساسية
            $(document).on('change', '.base-unit-radio', function () {
                $('.base-unit-hidden').val('false');
                $('.base-unit-radio').prop('checked', false);

                $(this).prop('checked', true);
                $(this).closest('tr').find('.base-unit-hidden').val('true');
            });

            function reIndexTable() {
                $('#tbl-product-units tbody tr').each(function (index, tr) {
                    $(tr).find('select, input').each(function (i, el) {
                        var name = $(el).attr('name');
                        if (name && name.startsWith('ProductUnits[')) {
                            var newName = name.replace(/\[\d+\]/, '[' + index + ']');
                            $(el).attr('name', newName);
                        }
                    });
                });
            }

            // تشغيل الدالة لأول مرة عند فتح الصفحة (مفيد جداً في شاشة الـ Edit لعرض الوحدات القديمة بشكل صحيح)
            checkDuplicateUnits();
        });
    </script>
}