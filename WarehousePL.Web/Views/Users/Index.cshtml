@using WarehouseBLL.BusinessServices.View_Models.Users
@using WarehouseBLL.Const

@model IEnumerable<UserViewModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery antiforgery
@{
    ViewBag.Title = _localization["Users"];
}

<div class="card">
    <div class="card-datatable text-nowrap" id="">
        <table class="js-table datatables-basic table table-bordered table-responsive">
            <thead>
                <tr>
                    <th>@_localization[@DisplayNames.Name]</th>
                    <th>@_localization[@DisplayNames.UserName]</th>
                    <th>@_localization[@DisplayNames.PhoneNumber]</th>
                    <th>@_localization[@DisplayNames.Role]</th>
                    <th>@_localization[@DisplayNames.Status]</th>
                    <th class="js-no-export" data-i18n="Edit"></th>
                    <th class="js-no-export" data-i18n="DeleteOrRestore"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <partial name="_Row" model="@user" />
                }
            </tbody>
        </table>
    </div>
</div>
<div id="create-button-data"
     data-address=@_localization["Users"]
     data-title=@_localization["AddNew"]
     data-url="@Url.Action("Create", "Users")"
     data-label="@_localization["AddUser"]"
     data-mode="modal">
</div>

<input type="hidden" name="__RequestVerificationToken" value="@antiforgery.GetAndStoreTokens(Context).RequestToken" />

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}