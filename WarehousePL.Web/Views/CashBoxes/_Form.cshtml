@using WarehouseBLL.FormViewModels.CashBox
@model CashBoxFormViewModel

<form asp-action="@(Model.Id == null ? "Create" : "Edit")"
      asp-controller="CashBoxes"
      method="post"
      class="js-form-element row g-3"
      data-modal="true">

    @if (Model.Id != null)
    {
        <input type="hidden" asp-for="Id" />
    }

    <div class="col-md-12">
        <label asp-for="Name" class="form-label">اسم الخزنة</label>
        <input asp-for="Name" class="form-control" placeholder="مثال: الخزنة الرئيسية، خزنة الكاشير" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="SelectedBranch" class="form-label">الفرع</label>
        <select asp-for="SelectedBranch" asp-items="Model.Branches" class="form-select select2">
            <option value="">-- اختر الفرع التابع له الخزنة --</option>
        </select>
        <span asp-validation-for="SelectedBranch" class="text-danger"></span>
    </div>

    @if (Model.Id == null)
    {
        <div class="col-md-12">
            <label asp-for="OpeningBalance" class="form-label">الرصيد الافتتاحي (البداية)</label>
            <input asp-for="OpeningBalance" type="number" step="0.01" class="form-control" placeholder="0.00" />
            <span asp-validation-for="OpeningBalance" class="text-danger"></span>
        </div>
    }

    <div class="col-12 text-center demo-vertical-spacing">
        <button type="submit" class="btn btn-primary me-sm-3 me-1">حفظ البيانات</button>
        <button type="reset" class="btn btn-label-secondary" data-bs-dismiss="modal" aria-label="Close">إلغاء</button>
    </div>
</form>