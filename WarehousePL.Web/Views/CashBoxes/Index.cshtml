@using WarehouseBLL.BusinessServices.View_Models.CashBox
@using WarehouseBLL.Const
@model IEnumerable<CashBoxViewModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery antiforgery

@{
    ViewBag.Title = "الخزائن المالية";
}

<div class="card">
    <div class="card-datatable text-nowrap">
        <table class="js-table datatables-basic table table-bordered table-responsive">
            <thead>
                <tr>
                    <th>اسم الخزنة</th>
                    <th>الفرع</th>
                    <th>الرصيد الحالي</th>
                    <th>الحالة</th>
                    <th>حركات النقدية</th>
                    <th class="js-no-export" data-i18n="Edit">تعديل</th>
                    <th class="js-no-export" data-i18n="DeleteOrRestore">حذف / استرجاع</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cashBox in Model)
                {
                    <partial name="_Row" model="@cashBox" />
                }
            </tbody>
        </table>
    </div>
</div>

<div id="create-button-data"
     data-address="الخزائن"
     data-title="إضافة خزنة جديدة"
     data-url="@Url.Action("Create", "CashBoxes")"
     data-label="إضافة خزنة"
     data-mode="modal"></div>

<input type="hidden" id="RequestVerificationToken" name="__RequestVerificationToken" value="@antiforgery.GetAndStoreTokens(Context).RequestToken" />

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}