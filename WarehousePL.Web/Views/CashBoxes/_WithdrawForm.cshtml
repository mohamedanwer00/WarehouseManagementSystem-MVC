@using WarehouseBLL.FormViewModels.CashBox
@model CashBoxTransactionFormViewModel

<form asp-action="Withdraw" asp-controller="CashBoxes" method="post" class="js-form-element row g-3" data-modal="true">
    <input type="hidden" asp-for="CashBoxId" />

    <div class="col-md-12 text-center mb-2">
        <h5 class="text-danger">سحب نقدي من: @Model.CashBoxName</h5>
    </div>

    <div class="col-md-12">
        <label asp-for="Amount" class="form-label">مبلغ السحب</label>
        <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" autofocus />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="Notes" class="form-label">السبب / الغرض من السحب</label>
        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="اكتب سبب السحب هنا..."></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="col-12 text-center demo-vertical-spacing">
        <button type="submit" class="btn btn-danger me-sm-3 me-1">تأكيد السحب</button>
        <button type="reset" class="btn btn-label-secondary" data-bs-dismiss="modal">إلغاء</button>
    </div>
</form>