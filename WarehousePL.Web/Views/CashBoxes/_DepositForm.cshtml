@using WarehouseBLL.FormViewModels.CashBox
@model CashBoxTransactionFormViewModel

<form asp-action="Deposit" asp-controller="CashBoxes" method="post" class="js-form-element row g-3" data-modal="true">
    <input type="hidden" asp-for="Id" />

    <div class="col-md-12 text-center mb-2">
        <h5 class="text-success">إيداع نقدي في: @Model.Name</h5>
    </div>

    <div class="col-md-12">
        <label asp-for="Amount" class="form-label">مبلغ الإيداع</label>
        <input asp-for="Amount" type="number" step="1.00" class="form-control" placeholder="0.00" autofocus />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="Notes" class="form-label">البيان / السبب</label>
        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="اكتب سبب الإيداع هنا..."></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="col-12 text-center demo-vertical-spacing">
        <button type="submit" class="btn btn-success me-sm-3 me-1">تأكيد الإيداع</button>
        <button type="reset" class="btn btn-label-secondary" data-bs-dismiss="modal">إلغاء</button>
    </div>
</form>

<script>
    $('.js-form-element').off('submit').on('submit', function (e) {
        e.preventDefault();

        var form = $(this);
        if (!form.valid()) return false;

        $.ajax({
            url: form.attr('action'),
            type: form.attr('method'),
            data: form.serialize(),
            success: function (response) {
                var modalEl = form.closest('.modal');
                if(modalEl.length > 0) {
                     var modalInstance = bootstrap.Modal.getInstance(modalEl[0]) || new bootstrap.Modal(modalEl[0]);
                     modalInstance.hide();
                }

                var cashBoxId = "@Model.Id";
                $('tr[data-id="' + cashBoxId + '"]').replaceWith(response);
            },
            error: function (xhr) {
                alert('حدث خطأ أثناء حفظ البيانات.');
            }
        });
    });
</script>