@using WarehouseBLL.Const
@using WarehouseBLL.FormViewModels.Warehouse

@model WarehouseFormViewModel

<form asp-action="@(Model?.Id > 0 ? "Edit" : "Create")"
      data-ajax-method="post"
      data-ajax="true"
      data-ajax-begin="onModalBegin"
      data-ajax-success="onModalSuccess"
      data-ajax-failure="showErrorMessage"
      data-ajax-complete="onModalComplete">
    @if (Model?.Id > 0)
    {
        <input type="hidden" asp-for="Id" />
    }
    <div class="mb-5">
        <label asp-for="Name"></label>
        <input type="text" class="form-control" placeholder="@_localization[DisplayNames.Name]" asp-for="Name" />
        <span asp-validation-for="Name" class="text-danger d-block"></span>
    </div>
    <div class="mb-5">
        <div class="mb-2">
            <label asp-for="Branches" class="form-label"></label>
            <select class="form-select form-select-solid js-select2" data-placeholder="@_localization[DisplayNames.Branch]" asp-for="SelectedBranch" asp-items="@Model?.Branches">
                <option></option>
            </select>
        </div>
        <span asp-validation-for="SelectedBranch" class="text-danger d-block"></span>
    </div>


    <partial name="_PopUpModelFooter" />
</form>