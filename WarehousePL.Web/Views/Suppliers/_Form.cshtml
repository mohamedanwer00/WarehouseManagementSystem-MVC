@model SupplierFormViewModel

@{
    var action = Model.Id.HasValue ? "Edit" : "Create";
}

<form asp-action="@action" asp-controller="Suppliers" method="post" id="supplier-form">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <div class="row g-3">

        <div class="col-12">
            <label asp-for="Name" class="form-label fw-bold">
                اسم المورد <span class="text-danger">*</span>
            </label>
            <input asp-for="Name" class="form-control" placeholder="اسم الشركة أو المورد" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="PhoneNumber" class="form-label fw-bold">
                رقم الهاتف <span class="text-danger">*</span>
            </label>
            <input asp-for="PhoneNumber" class="form-control" placeholder="010XXXXXXXX" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Address" class="form-label fw-bold">
                العنوان <span class="text-danger">*</span>
            </label>
            <input asp-for="Address" class="form-control" placeholder="المحافظة، المدينة، الشارع" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        @if (!Model.Id.HasValue)
        {
            <div class="col-md-6">
                <label asp-for="OpeningBalance" class="form-label fw-bold">
                    الرصيد الافتتاحي
                </label>
                <input asp-for="OpeningBalance" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="OpeningBalance" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="OpeningBalanceType" class="form-label fw-bold">
                    طبيعة الحساب
                </label>
                <select asp-for="OpeningBalanceType"
                        asp-items="Model.BalanceTypes"
                        class="form-select">
                </select>
                <span asp-validation-for="OpeningBalanceType" class="text-danger"></span>
            </div>
        }
        else
        {
            <input type="hidden" asp-for="OpeningBalance" />
            <input type="hidden" asp-for="OpeningBalanceType" />
        }

    </div>

    <div class="modal-footer border-top px-0 pb-0 mt-4 gap-2">
        <button type="submit" class="btn btn-primary">
            @(Model.Id.HasValue ? "تعديل" : "حفظ")
        </button>

        <button type="button"
                class="btn btn-label-secondary"
                data-bs-dismiss="modal">
            إغلاق
        </button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />