@using WarehouseBLL.BusinessServices.View_Models.ProductWarehouse
@model IEnumerable<ProductWarehouseViewModel>

@{
    ViewBag.Title = "جرد كميات المخازن";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center border-bottom mb-3">
        <h5 class="mb-0">تقرير كميات الأصناف الحالية في المخازن (الجرد الفعلي)</h5>
        <div class="d-flex gap-2">
            <!-- زرار اختياري لتحديث الأرقام أو التصدير -->
            <button type="button" onclick="window.location.reload();" class="btn btn-sm btn-label-secondary">
                <i class="bx bx-refresh me-1"></i> تحديث البيانات
            </button>
        </div>
    </div>

    <div class="card-datatable text-nowrap">
        <table class="js-table datatables-basic table table-bordered table-responsive">
            <thead class="table-light">
                <tr>
                    <th>كود المنتج</th>
                    <th>اسم المنتج</th>
                    <th>المخزن</th>
                    <th>الكمية المتاحة</th>
                    <th>الوحدة</th>
                    <th class="js-no-export">الحالة</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <partial name="_Row" model="@item" />
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}