@using WarehouseBLL.BusinessServices.View_Models.Customer
@using WarehouseBLL.Const
@model CustomerViewModel

<tr id="row-@Model.Id" data-id="@Model.Id">

    <td class="fw-bold text-heading">@Model.Name</td>

    <td>@Model.PhoneNumber</td>

    <td class="text-muted">@Model.Address</td>

    <td>
        @if (Model.CustomerType == CustomerType.Wholesale)
        {
            <span class="badge bg-label-info">جملة</span>
        }
        else
        {
            <span class="badge bg-label-secondary">قطاعي</span>
        }
    </td>

    <td>
        @if (Model.CurrentBalance >= 0)
        {
            <span class="text-success fw-bold">
                @Model.CurrentBalance.ToString("N2") (دائن)
            </span>
        }
        else
        {
            <span class="text-danger fw-bold">
                @Math.Abs(Model.CurrentBalance).ToString("N2") (مدين)
            </span>
        }
    </td>

    <td>
        <partial name="_LastActionBadge" model="@Model.LastAction" />
    </td>

    <td>
        <a href="javascript:;"
           data-url="/Customers/Edit/@Model.Id"
           class="btn btn-sm btn-label-primary js-render-modal"
           data-title="@_localization[DisplayNames.Edit]"
           data-update="true">
            @_localization[DisplayNames.Edit]
        </a>
    </td>

    <td>
        @if (Model.LastAction != LastActionName.Delete)
        {
            <a href="javascript:;"
               data-url="/Customers/Delete/@Model.Id"
               class="btn btn-sm btn-label-danger js-toggle-status"
               data-id="@Model.Id"
               data-confirm-message="@_localization["confirmText"]">
                @_localization[DisplayNames.Delete]
            </a>
        }
        else
        {
            <a href="javascript:;"
               data-url="/Customers/Restore/@Model.Id"
               class="btn btn-sm btn-label-success js-toggle-status"
               data-id="@Model.Id"
               data-confirm-message="@_localization["confirmText"]">
                @_localization[DisplayNames.Restore]
            </a>
        }
    </td>

</tr>